# ==================================================================
# UGCForge — Environment Variables
# Copy this file to .env.local and fill in the values
# ==================================================================

# ---- Authentication ----
# Required: Secret key for NextAuth JWT signing (generate with: openssl rand -base64 32)
AUTH_SECRET=

# Public URL of your app (used for callbacks, OAuth redirects)
NEXTAUTH_URL=http://localhost:3000

# ---- LLM / AI Provider ----
# Supported providers: openrouter, groq, together, huggingface, mistral
LLM_PROVIDER=openrouter

# Model to use (leave empty for provider default)
# OpenRouter: nvidia/nemotron-nano-9b-v2:free, mistralai/mistral-7b-instruct:free
# Groq: llama3-8b-8192, mixtral-8x7b-32768
# Together: mistralai/Mistral-7B-Instruct-v0.2
# HuggingFace: mistralai/Mistral-7B-Instruct-v0.2
# Mistral: mistral-small-latest
LLM_MODEL=

# API key for your chosen LLM provider
LLM_API_KEY=

# ---- Media ----
# Pexels API key for stock video backgrounds (https://www.pexels.com/api/)
PEXELS_API_KEY=

# ---- Video Rendering ----
# Maximum concurrent video renders (default: 2)
RENDER_MAX_CONCURRENT=2

# Video render timeout in milliseconds (default: 120000 = 2 minutes)
RENDER_TIMEOUT_MS=120000

# Maximum queued renders before rejecting (default: 10)
RENDER_MAX_QUEUE=10

# ---- Logging ----
# Log level: debug, info, warn, error (default: info)
LOG_LEVEL=info

# ---- Optional: Redis ----
# Redis URL for persistent rate limiting (falls back to in-memory if not set)
# REDIS_URL=redis://localhost:6379
