// PostgreSQL-ready schema
// To switch from SQLite to PostgreSQL:
// 1. Set DATABASE_URL="postgresql://user:password@host:5432/ugcforge?schema=public" in .env
// 2. Copy this file to prisma/schema.prisma (replacing the SQLite version)
// 3. Run: npx prisma migrate dev --name switch-to-postgres
// 4. Run: npx prisma generate
// 5. Restart the dev server
//
// Key differences from SQLite schema:
// - datasource provider changed to "postgresql"
// - JSON string fields upgraded to native Json type for better querying
// - Text fields use @db.Text for long content

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String?
  passwordHash String?
  createdAt    DateTime @default(now())

  projects         Project[]
  generatedContent GeneratedContent[]
  videos           Video[]
  usageRecords     UsageRecord[]
  brandKit         BrandKit?
  calendarEvents   CalendarEvent[]
}

model Project {
  id        String   @id @default(cuid())
  name      String
  userId    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user             User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  generatedContent GeneratedContent[]

  @@index([userId])
}

model GeneratedContent {
  id                 String   @id @default(cuid())
  projectId          String?
  userId             String
  productName        String
  productDescription String   @db.Text
  targetAudience     String
  platform           String
  contentGoal        String
  tone               String
  ctaType            String
  hookBank           Json     // Array of hook strings
  script             String   @db.Text
  altAngles          Json     // Object with alternative angles
  caption            String   @db.Text
  hashtags           Json     // Array of hashtag strings
  ctaVariations      Json     // Array of CTA strings
  thumbnailTexts     Json     // Array of thumbnail text strings
  engagementBaits    Json     // Array of engagement bait strings
  repurposedContent  String   @db.Text
  abVariants         Json     // Array of A/B variant objects
  rawOutput          String?  @db.Text
  isFavorite         Boolean  @default(false)
  createdAt          DateTime @default(now())

  user           User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  project        Project?          @relation(fields: [projectId], references: [id], onDelete: SetNull)
  videos         Video[]
  calendarEvents CalendarEvent[]

  @@index([userId])
  @@index([projectId])
}

model Video {
  id               String   @id @default(cuid())
  userId           String
  contentId        String?
  template         String
  platform         String
  hook             String   @db.Text
  scriptLines      Json     // Array of script line strings
  cta              String
  voiceId          String?
  audioUrl         String?
  audioDuration    Int?     // ms
  wordBoundaries   Json?    // Array of word boundary objects
  backgroundImage  String?
  captionStyle     String?
  hookStyle        String?
  colorAccent      String?
  videoPath        String?
  thumbnailPath    String?
  width            Int?
  height           Int?
  durationMs       Int?
  status           String   @default("draft") // draft, rendering, completed, failed
  createdAt        DateTime @default(now())

  user    User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  content GeneratedContent? @relation(fields: [contentId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([contentId])
  @@index([status])
}

model BrandKit {
  id              String   @id @default(cuid())
  userId          String   @unique
  brandName       String?
  primaryColor    String   @default("#A855F7")
  secondaryColor  String   @default("#EC4899")
  accentColor     String   @default("#3B82F6")
  logoUrl         String?
  defaultVoice    String   @default("jenny")
  defaultTone     String   @default("casual")
  defaultPlatform String   @default("tiktok")
  tagline         String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model UsageRecord {
  id     String @id @default(cuid())
  userId String
  date   String
  count  Int    @default(0)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@index([userId])
}

model CalendarEvent {
  id        String   @id @default(cuid())
  userId    String
  contentId String?
  title     String
  platform  String
  date      String   // YYYY-MM-DD format
  time      String?  // HH:mm format
  status    String   @default("scheduled") // scheduled, posted, missed
  notes     String?  @db.Text
  color     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user    User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  content GeneratedContent? @relation(fields: [contentId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([contentId])
  @@index([date])
  @@index([status])
}
