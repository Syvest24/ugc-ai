# ==================================================================
# UGCForge — Environment Variables
# Copy this file to .env.local and fill in the values
# ==================================================================

# ---- Database ----
# PostgreSQL connection string (required)
# For Vercel: Use Neon, Supabase, or PlanetScale
# Example: postgresql://user:password@host:5432/dbname?sslmode=require
DATABASE_URL=

# ---- Authentication ----
# Required: Secret key for NextAuth JWT signing (generate with: openssl rand -base64 32)
AUTH_SECRET=

# Public URL of your app (used for callbacks, OAuth redirects)
# Vercel sets this automatically, only needed for local dev
NEXTAUTH_URL=http://localhost:3000

# ---- Google OAuth (optional) ----
# Create credentials at https://console.cloud.google.com/apis/credentials
# Authorized redirect URI: <NEXTAUTH_URL>/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ---- LLM / AI Provider ----
# Supported providers: openrouter, groq, together, huggingface, mistral
LLM_PROVIDER=openrouter

# Model to use (leave empty for provider default)
# OpenRouter: nvidia/nemotron-nano-9b-v2:free, mistralai/mistral-7b-instruct:free
# Groq: llama3-8b-8192, mixtral-8x7b-32768
# Together: mistralai/Mistral-7B-Instruct-v0.2
# HuggingFace: mistralai/Mistral-7B-Instruct-v0.2
# Mistral: mistral-small-latest
LLM_MODEL=

# API key for your chosen LLM provider
LLM_API_KEY=

# ---- Media ----
# Pexels API key for stock video backgrounds (https://www.pexels.com/api/)
PEXELS_API_KEY=

# ---- Image Generation ----
# Supported providers: pollinations (free, default), gemini (free tier), together, stability, replicate
# This is the default provider. Users can also select per-request in the UI.
IMAGE_PROVIDER=pollinations

# Google Gemini API key (free tier supports image generation)
# Get one at: https://aistudio.google.com/apikey
# GEMINI_API_KEY=

# Only required for Together.ai or Stability AI image generation
# TOGETHER_API_KEY=
# STABILITY_API_KEY=

# ---- Video Rendering ----
# Maximum concurrent video renders (default: 2)
RENDER_MAX_CONCURRENT=2

# Video render timeout in milliseconds (default: 120000 = 2 minutes)
RENDER_TIMEOUT_MS=120000

# Maximum queued renders before rejecting (default: 10)
RENDER_MAX_QUEUE=10

# ---- Logging ----
# Log level: debug, info, warn, error (default: info)
LOG_LEVEL=info

# ---- Optional: Redis ----
# Redis URL for persistent rate limiting (falls back to in-memory if not set)
# REDIS_URL=redis://localhost:6379
